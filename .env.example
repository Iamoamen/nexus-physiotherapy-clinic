# ============================================================
# .env.example — Copy to .env and fill in ALL values
# NEVER commit .env to git — it is in .gitignore
# ============================================================

# ── Your domains ─────────────────────────────────────────────
# Update nginx/nexus.conf with these same values
PUBLIC_DOMAIN=nexusclinic.eg
ADMIN_DOMAIN=admin.nexusclinic.eg

# ── Database ─────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
DB_ROOT_PASS=CHANGE_ME_STRONG_ROOT_PASSWORD
DB_PASS=CHANGE_ME_STRONG_DB_PASSWORD

# ── Admin dashboard ───────────────────────────────────────────
# Min 16 chars — change immediately after first login
ADMIN_PASS=CHANGE_ME_STRONG_ADMIN_PASSWORD

# ── SMTP (Brevo — free 300 emails/day) ───────────────────────
MAIL_HOST=smtp-relay.brevo.com
MAIL_PORT=587
MAIL_USER=your-brevo-login@email.com
MAIL_PASS=your-brevo-smtp-api-key
